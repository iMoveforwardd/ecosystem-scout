# GitHub token for enrichment (raises API rate limit from 60 to 5000 req/hr)
# Use a FINE-GRAINED PAT — not a classic token.
# Required scopes: Contents (read), Metadata (read) on public repos only.
# Do NOT grant write access, private repo access, or admin scopes.
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=ghp_your_token_here

# DB and queue live OUTSIDE Google Drive to prevent sync conflicts.
# The directory C:\Users\vjlew\ecosystem-scout\ must exist (created once manually).
SCOUT_DB=C:\Users\vjlew\ecosystem-scout\scout.db
SCOUT_QUEUE=C:\Users\vjlew\ecosystem-scout\queue.json
